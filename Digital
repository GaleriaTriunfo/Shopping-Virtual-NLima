     <h2 class="titulo-secao">Destaques do Shopping</h2>
     <div class="container-noticias" id="lista-noticias"></div>

     <script>
         const noticiasSuporte = [
              { title: "Tendências de Moda para a Estação", summary: "Confira as principais coleções e peças que estão dominando as vitrines virtuais este mês.", url: "#", img: "https://images.unsplash.com/photo-1483985988355-763728e1935b?w=400&h=250&fit=crop" },
              { title: "Guia de Eletrônicos e Gadgets", summary: "Os dispositivos inteligentes que prometem facilitar sua rotina doméstica e profissional.", url: "#", img: "https://images.unsplash.com/photo-1468495244123-6c6c332eeece?w=400&h=250&fit=crop" },
              { title: "Gastronomia Integrada", summary: "Descubra novas opções de alimentação com entrega rápida e cupons exclusivos no portal.", url: "#", img: "https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=400&h=250&fit=crop" },
              { title: "Design de Interiores e Conforto", summary: "Móveis e itens de decoração modernos para transformar o ambiente do seu lar ou escritório.", url: "#", img: "https://images.unsplash.com/photo-1524758631624-e2822e304c36?w=400&h=250&fit=crop" },
              { title: "Cosméticos e Bem-Estar", summary: "Encontre produtos de cuidados pessoais com formulações tecnológicas e sustentáveis.", url: "#", img: "https://images.unsplash.com/photo-1556228720-195a672e8a03?w=400&h=250&fit=crop" },
              { title: "Esportes e Vida Saudável", summary: "Equipamentos e vestuários recomendados para otimizar suas atividades físicas diárias.", url: "#", img: "https://images.unsplash.com/photo-1517838277536-f5f99be501cd?w=400&h=250&fit=crop" }
         ];

         function carregarNoticias() {
              const container = document.getElementById('lista-noticias');
              
              noticiasSuporte.forEach(item => {
                   const card = document.createElement('div');
                   card.className = 'card-noticia';
                   
                   card.innerHTML = `
                       <img src="${item.img}" alt="Notícia">
                       <div class="conteudo-noticia">
                           <p class="titulo-noticia">${item.title}</p>
                           <p class="resumo-noticia">${item.summary}</p>
                           <a href="${item.url}" class="btn-ler-mais">Ver detalhes →</a>
                       </div>
                   `;
                   container.appendChild(card);
              });
         }

         carregarNoticias();
     </script>
